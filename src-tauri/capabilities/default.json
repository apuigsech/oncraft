{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for OnCraft",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/agent-bridge",
          "sidecar": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/agent-bridge",
          "sidecar": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:allow-open",
    "fs:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/.oncraft/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/.oncraft/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" },
        { "path": "/var/folders/**" }
      ]
    },
    {
      "identifier": "fs:allow-write",
      "allow": [
        { "path": "$HOME/.oncraft/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/.oncraft/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" },
        { "path": "$TEMP/**" },
        { "path": "/var/folders/**" }
      ]
    }
  ]
}
