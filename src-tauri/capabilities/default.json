{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for ClaudBan",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-homebrew",
          "cmd": "/opt/homebrew/bin/claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-usr-local",
          "cmd": "/usr/local/bin/claude",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-homebrew",
          "cmd": "/opt/homebrew/bin/claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "claude-usr-local",
          "cmd": "/usr/local/bin/claude",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:allow-open",
    "fs:default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
