{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnCraft",
  "identifier": "ai.oncraft.app",
  "build": {
    "beforeDevCommand": "pnpm build:sidecar && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:sidecar && pnpm build",
    "frontendDist": "../.output/public"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "windows": [
      {
        "title": "OnCraft",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Kanban board for managing Claude Code sessions",
    "longDescription": "OnCraft is a desktop application that provides a Kanban board interface for managing Claude Code sessions. Each card maps to a conversation, moving through a configurable workflow from brainstorming to implementation.",
    "externalBin": ["binaries/agent-bridge"],
    "resources": ["../presets/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
