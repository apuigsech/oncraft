{
  "name": "oncraft",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt generate",
    "build:sidecar": "cd src-sidecar && ~/.bun/bin/bun install && ~/.bun/bin/bun build --compile --target=bun agent-bridge.ts --outfile ../src-tauri/binaries/agent-bridge-$(rustc -vV | sed -n 's/host: //p')",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:sync": "node -e \"const v=require('./package.json').version;const f='src-tauri/Cargo.toml';let t=require('fs').readFileSync(f,'utf8');t=t.replace(/^version = \\\".*\\\"/m,'version = \\\"'+v+'\\\"');require('fs').writeFileSync(f,t);console.log('Synced version '+v+' to Cargo.toml');\""
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.0",
    "@pinia/nuxt": "^0.11.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.4",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@types/js-yaml": "^4.0.9",
    "@types/sortablejs": "^1.15.9",
    "@types/uuid": "^11.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.8",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1"
  }
}
